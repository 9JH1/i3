: 1744275600:0;#!/bin/bash\
\
# Define old and new path prefix\
old_prefix="/drive"\
new_prefix="/drive/say gex"\
\
# Find all symlinks on the system (excluding /proc and /sys to avoid errors)\
find / -path /proc -prune -o -path /sys -prune -o -type l -print 2>/dev/null | while read -r link; do\
    target=$(readlink "$link")\
\
    # Only update links that point to /drive or its subpaths\
    if [[ "$target" == "$old_prefix"* ]]; then\
        # Create the new target by replacing the prefix\
        new_target="${target/$old_prefix/$new_prefix}"\
\
        echo "Updating link: $link"\
        echo "  Old target: $target"\
        echo "  New target: $new_target"\
\
        # Recreate the symlink\
        ln -snf "$new_target" "$link"\
    fi\
done\

