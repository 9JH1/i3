: 1743731161:0;#!/bin/bash\
while true; do\
  # Get the current song file from cmus\
  file=$(cmus-remote -Q | grep "file" | cut -d " " -f 2-)\
  # Derive the .lrc file name\
  lrc_file="${file%.*}.lrc"\
  if [ -f "$lrc_file" ]; then\
    clear\
    echo "Lyrics for: $(basename "$file")"\
    cat "$lrc_file"\
  else\
    echo "No .lrc file found for $(basename "$file")"\
  fi\
  sleep 1 # Adjust refresh rate\
done
: 1743731216:0;nvim cmus-lrc.py
: 1743731222:0;python cmus-lrc.py
: 1743731313:0;#!/bin/bash\
\
# Function to convert LRC timestamp (e.g., [00:12.34]) to seconds\
timestamp_to_seconds() {\
    local ts="$1"  # Expecting format like [mm:ss.xx]\
    local min=$(echo "$ts" | grep -oP '\[\d+' | tr -d '[')\
    local sec=$(echo "$ts" | grep -oP '\d+\.\d+' || echo "0")\
    echo "$(echo "$min * 60 + $sec" | bc)"\
}\
\
# Main loop\
while true; do\
    # Get current song file and playback position from cmus\
    status=$(cmus-remote -Q 2>/dev/null)\
    if [ $? -ne 0 ]; then\
        echo "cmus is not running."\
        sleep 1\
        continue\
    fi\
\
    file=$(echo "$status" | grep "^file" | cut -d " " -f 2-)\
    position=$(echo "$status" | grep "^position" | cut -d " " -f 2)  # Position in seconds\
\
    # Derive the .lrc file name\
    lrc_file="${file%.*}.lrc"\
\
    if [ ! -f "$lrc_file" ]; then\
        clear\
        echo "No .lrc file found for $(basename "$file")"\
        sleep 1\
        continue\
    fi\
\
    # Read the .lrc file and find the current line\
    current_line=""\
    previous_time=0\
\
    while IFS= read -r line; do\
        # Extract timestamp from lines like [mm:ss.xx]Lyric text\
        if [[ "$line" =~ ^\[[0-9]{2}:[0-9]{2}\.[0-9]{2}\] ]]; then\
            timestamp=$(echo "$line" | grep -oP '^\[\d{2}:\d{2}\.\d{2}\]')\
            lyric=$(echo "$line" | sed 's/^\[\d\{2\}:\d\{2\}\.\d\{2\}\]//')\
            time_in_seconds=$(timestamp_to_seconds "$timestamp")\
\
            # If current position is past this timestamp but before the next one\
            if (( $(echo "$position >= $previous_time && $position < $time_in_seconds" | bc -l) )); then\
                current_line="$lyric"\
                break\
            elif (( $(echo "$position >= $time_in_seconds" | bc -l) )); then\
                current_line="$lyric"\
                previous_time="$time_in_seconds"\
            fi\
        fi\
    done < "$lrc_file"\
\
    # Display the current lyric\
    clear\
    echo "Now playing: $(basename "$file")"\
    echo "Position: $position seconds"\
    if [ -n "$current_line" ]; then\
        echo "Lyrics: $current_line"\
    else\
        echo "Lyrics: (No matching lyric line)"\
    fi\
\
    # Refresh every half second for smoother updates\
    sleep 0.5\
done
: 1743731353:0;./cmus-lrc
