: 1744620331:0;xprop -id 0x5800001
: 1744620389:0;#!/bin/bash\
# File: xwinwrap-custom-class.sh\
\
# Launch xwinwrap with your arguments\
xwinwrap -g 1920x1080 -st -sp -s -fdt -ni -b -nf -un -fs -- mpv -wid WID --vo=gpu --loop --no-sub --no-terminal --no-input-default-bindings --no-config --hwdec=auto --vo=gpu --profile=low-latency --no-audio --no-osc --no-cache --video-sync=display-resample --framedrop=vo --volume=0 --speed=1 --video-zoom=0.00 "$1" &\
XWINWRAP_PID=$!\
\
# Wait for the window to appear\
sleep 1\
\
# Find the window by PID\
WINDOW_ID=$(xdotool search --pid $XWINWRAP_PID)\
\
if [ -n "$WINDOW_ID" ]; then\
    # Set custom WM_CLASS (instance and class name)\
    xprop -id $WINDOW_ID -f WM_CLASS 8s -set WM_CLASS "CustomXwinwrap,CustomXwinwrap"\
    echo "Set WM_CLASS to CustomXwinwrap for window $WINDOW_ID"\
else\
    echo "Could not find xwinwrap window"\
    exit 1\
fi\
\
# Wait for xwinwrap to exit\
wait $XWINWRAP_PID
