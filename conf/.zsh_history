: 1743731161:0;#!/bin/bash\
while true; do\
  # Get the current song file from cmus\
  file=$(cmus-remote -Q | grep "file" | cut -d " " -f 2-)\
  # Derive the .lrc file name\
  lrc_file="${file%.*}.lrc"\
  if [ -f "$lrc_file" ]; then\
    clear\
    echo "Lyrics for: $(basename "$file")"\
    cat "$lrc_file"\
  else\
    echo "No .lrc file found for $(basename "$file")"\
  fi\
  sleep 1 # Adjust refresh rate\
done
