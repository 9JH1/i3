[colors]
color0=${xrdb:color0}
color1=${xrdb:color1}
color2=${xrdb:color2}
color3=${xrdb:color3}
color4=${xrdb:color4}
color5=${xrdb:color5}
color6=${xrdb:color6}
color7=${xrdb:color7}
color8=${xrdb:color8}
color9=${xrdb:color9}
color10=${xrdb:color10}
color11=${xrdb:color11}
color12=${xrdb:color12}
color13=${xrdb:color13}
color14=${xrdb:color14}
background = ${colors.color0}
background-alt = ${colors.color3}
foreground = ${colors.color3}
foreground-alt = ${colors.color2}
primary = ${colors.color5}
secondary = ${colors.color4}
module_foreground = ${colors.color0}
alert = "#ff0000"
disabled = ${colors.color5}
level0=${colors.2}
level1=${colors.module_foreground}
level2=${colors.module_foreground}
level3=${colors.alert}

[bar/bar_main]
fixed-center = true
;border-right-size = 10pt 
;border-left-size = 10pt 
;border-top-size = 5pt
;radius = 10pt 
border-color = #00000000
modules-left = powermenu space  seperator xworkspaces seperator polywins
modules-right = user user_seperator audio audio_seperator notify notify_seperator ram ram_seperator cpu cpu_temp cpu_seperator systray tray_seperator date
height = 2.8%
;padding = 1 
foreground = ${colors.foreground}
font-3 = "Mononoki Nerd Font:style=Regular:size=30;6.6"
font-2 = "Material Icons:size=20"
font-1 = "MonaspiceRN NFM:style=Bold:size=15;2.5"
font-0 = "Mononoki Nerd Font:style=Regular:size=15;2.1"
background=${colors.background}
line-size = 2

[module/battery]
type =internal/battery
low-at = 20
time-format = %H:%M
label-low = %percentage%%-%time% left
format-low = !<label-low>
format-low-foreground = ${colors.foreground}
format-low-background = ${colors.bad}
label-charging = +%percentage%
format-charging = <label-charging>
format-charging-foreground = ${colors.foreground}
format-charging-background = ${colors.good}
label-discharging = %{T3}%percentage%%%{T-}-%{T2}%time%%{T-}
format-discharging = <label-discharging>
format-discharging-foreground = ${colors.foreground}
format-discharging-background = ${colors.medium}
label-full = %{T3}%percentage%%{T-}
format-full = <label-full>
format-full-foreground = ${colors.foreground}
format-full-background = ${colors.good}

[module/user]
type=custom/script
exec = "echo %{T2}$USER %{T-}"
interval = 600000000000000
format-foreground = ${colors.module_foreground}
format-background = ${colors.color4}

[module/user_seperator]
type=custom/text
label = "%{T4}%{T-}"
format-background = ${colors.color4}
format-foreground = ${colors.color5}

[module/audio]
type = internal/pulseaudio
format-volume = <label-volume>
label-volume = " %percentage%% "
label-muted = "Muted"
format-muted-background=${colors.color5}
format-volume-background=${colors.color5}
format-volume-foreground=${colors.module_foreground}


[module/audio_seperator]
type=custom/text
label = "%{T4}%{T-}"
format = <label>
format-foreground=${colors.color1}
format-background=${colors.color5}


[module/notify]
type=custom/script 
exec=echo " Notifications: $(~/.config/i3/src/notify.sh) "
interval=1
click-left = "dunstctl set-paused toggle"
format-background = ${colors.color1}
format-foreground = ${colors.module_foreground}


[module/notify_seperator]
type=custom/text
label = "%{T4}%{T-}"
format = <label>
format-foreground=${colors.color5}
format-background=${colors.color1}

[module/ram]
type=internal/memory
interval=5
warn-percentage=95 
label = %percentage_used%%
format = "  <label> <bar-used>"
format-background = ${colors.color5}
format-foreground = ${colors.module_foreground}
label-warn = !%free% left
format-warn = <label-warn>
bar-used-indicator = 
bar-used-foreground-0 = ${colors.level0}
bar-used-foreground-1 = ${colors.level1}
bar-used-foreground-2 = ${colors.level2}
bar-used-foreground-3 = ${colors.level3}
format-warn-foreground= ${colors.alert}
format-warn-background = ${colors.color5}
bar-used-width = 10
bar-used-fill = ▐
bar-used-empty = ▐
bar-used-empty-foreground = ${colors.disabled}

[module/ram_seperator]
type=custom/text
label = "%{T4}%{T-}"
format = <label>
format-foreground=${colors.color3}
format-background=${colors.color5}

[module/cpu]
type=internal/cpu
interval = 5
warn-percentage = 95
label-warn = !%percentage%
format-warn = " <label-warn> <ramp-coreload>"
format-background = ${colors.color3}
format-foreground = ${colors.module_foreground}
format-warn-foreground = ${colors.alert}
format-warn-background = ${colors.color3}
label = %percentage%%
format = " <label> <ramp-coreload>"
ramp-coreload-spacing = 0
ramp-coreload-0 = ▁
ramp-coreload-1 = ▂
ramp-coreload-2 = ▃
ramp-coreload-3 = ▄
ramp-coreload-4 = ▅
ramp-coreload-5 = ▆
ramp-coreload-6 = ▇
ramp-coreload-7 = █

[module/cpu_temp]
type = custom/script
interval = 5
exec = echo " $(sensors | grep "Package id 0:" | tr -d '+' | awk '{print $4}') "
format-background = ${colors.color3}
format-foreground = ${colors.module_foreground}

[module/cpu_seperator]
type=custom/text
label = "%{T4}%{T-}"
format = <label>
format-foreground=${colors.color4}
format-background=${colors.color3}

[module/systray]
type = internal/tray
tray-spacing = 4pt
tray-size = 20
format-background = ${colors.color4}
tray-background= ${colors.color4}
format-foreground = ${colors.module_foreground}
tray-foreground = ${colors.module_foreground}

[module/tray_seperator]
type=custom/text
label = "%{T4}%{T-}"
format = <label>
format-foreground=${colors.color5}
format-background=${colors.color4}

[module/date]
type = internal/date
interval = 1
format-foreground = ${colors.module_foreground}
format-background = ${colors.color5}
date = "󰃭 %{T2}%l:%M %p %{T-}"
date-alt = %l:%M %p | %Y-%m-%d | %H:%M:%S

[module/date_suffix]
type=custom/text
label = " "
format-background=${colors.color5}


[module/xworkspaces]
type = internal/xworkspaces
label-active = %{T2}%name%%icon%%{T-}
label-active-padding = 1
label-active-foreground = ${colors.foreground-alt}
label-active-underline = ${colors.primary}
label-occupied = %name%%icon%
label-occupied-padding = 1
label-urgent = %name%%icon%
label-urgent-underline = ${colors.alert}
label-urgent-padding = 1
label-empty = %name%%icon%
label-empty-padding = 1
label-visible = %name%%icon%
workspace-count = 10



[module/space]
type = custom/text
content = " "
[module/seperator]
type = custom/text
format = <label>
format-foreground = ${colors.background-alt}
label = "%{T2} | %{T-}"

[module/polywins]
type = custom/script
exec = /home/$USER/.config/i3/src/window.sh 2>/dev/null
format = <label>
label = "%{T2}%output%%{T-}"  
label-padding = 1
tail = true

[module/powermenu]
type = custom/text
label  = " "
format = <label>
click-right="shutdown now"
click-left="reboot"
click-middle="systemctl suspend"
